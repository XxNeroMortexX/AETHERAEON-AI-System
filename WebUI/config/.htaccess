# ============================
# Aetheraeon Security
# ============================

Options -Indexes

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block sensitive artifacts and every PHP script except the generic database
# health endpoint. The config directory is denied again in its own .htaccess.
<FilesMatch "(?i)^(?:db_config\.php|\.env|.*\.(?:ini|log|sql|db|sqlite|bak|old|orig|tmp|ya?ml|toml|conf)|(?!db_health\.php$).*\.php)$">
    Require all denied
</FilesMatch>

ServerSignature Off

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
