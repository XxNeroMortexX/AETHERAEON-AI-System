# MariaDB connection used by core/config_loader.py
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=aetheraeon
DB_USER=aetheraeon_app
DB_PASS=replace_with_a_strong_database_password

# Flask session signing key. Generate one with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_random_64_character_hex_value

# Optional n8n webhook/health endpoint override
N8N_URL=http://127.0.0.1:5678

# Optional: only required when web_search.provider is "google_cse".
# Leave blank when using the built-in DuckDuckGo provider.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
